{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    // Pure source package consumed by bundlers (Astro / Next / Convex), so use
    // bundler resolution — matches how it's actually imported.
    "module": "Preserve",
    "moduleResolution": "Bundler"
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
