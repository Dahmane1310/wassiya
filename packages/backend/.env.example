# This file is written automatically by `npx convex dev` (the managed WorkOS
# AuthKit flow) — you normally do NOT edit it by hand. It is shown here only to
# document what ends up in packages/backend/.env.local. .env.local is gitignored.

# Set by `convex dev`:
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Written by the managed WorkOS AuthKit provisioning (convex.json localEnvVars):
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3001/callback

# NOTE: the Convex *deployment* env (separate store) also needs:
#   WORKOS_CLIENT_ID         (set by the managed flow; for convex/auth.config.ts)
#   WORKOS_WEBHOOK_SECRET    (you set via `npx convex env set` — see README)
# Verify with: npx convex env list
