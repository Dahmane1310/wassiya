# Copy to .env.local and fill in. EXPO_PUBLIC_* vars are embedded in the app
# bundle (public by design) — only put public values here, never WORKOS_API_KEY.

# Convex deployment URL (same value as apps/web NEXT_PUBLIC_CONVEX_URL).
EXPO_PUBLIC_CONVEX_URL=

# WorkOS public client id (mirror from packages/backend/.env.local WORKOS_CLIENT_ID).
EXPO_PUBLIC_WORKOS_CLIENT_ID=

# Mobile OAuth callback. Must match the app `scheme` in app.json and be registered
# in WorkOS (via packages/backend/convex.json authKit redirectUris).
EXPO_PUBLIC_WORKOS_REDIRECT_URI=wassiya://callback

# Web release-portal base URL — beneficiary invite links point here
# (https://<web>/invite/<token>). Dev: http://localhost:3001
EXPO_PUBLIC_WEB_URL=
