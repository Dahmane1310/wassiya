{
  "expo": {
    "name": "Wassiya",
    "slug": "wassiya-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "wassiya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fiveangles.wassiya"
    },
    "android": {
      "package": "com.fiveangles.wassiya"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-status-bar",
      "expo-web-browser",
      "react-native-quick-crypto",
      "expo-build-properties",
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
