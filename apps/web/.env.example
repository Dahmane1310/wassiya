# Copy to .env.local and fill in. .env.local is gitignored.
# See the root README "Bootstrapping" section for where each value comes from.

# Convex deployment URL for the browser client (same deployment as the backend).
NEXT_PUBLIC_CONVEX_URL=

# --- WorkOS AuthKit (server + client) ---
# Mirror these two from packages/backend/.env.local after `npx convex dev`.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Generate with: openssl rand -base64 24  (must be >= 32 chars)
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3001/callback
