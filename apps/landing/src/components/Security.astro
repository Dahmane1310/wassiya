---
import Icon from "./Icon.astro"
import IconBadge from "./IconBadge.astro"
import Kicker from "./Kicker.astro"
import Section from "./Section.astro"
import type { Dict } from "../i18n/types"

interface Props {
  t: Dict
}
const { t } = Astro.props
---

<Section id="security">
  <div class="grid items-center gap-10 md:grid-cols-[1.1fr_0.9fr] md:gap-16">
    <div class="reveal">
      <div
        class="relative overflow-hidden rounded-[var(--radius)] p-9 text-white shadow-2xl"
        style="background:linear-gradient(150deg, var(--espresso), var(--espresso-2));min-height:340px"
      >
        <div
          class="absolute -top-10 -end-8 h-[200px] w-[200px] rounded-full opacity-50"
          style="background:radial-gradient(circle, color-mix(in oklch, var(--gold) 40%, transparent), transparent 70%)"
        >
        </div>
        <div class="relative">
          <div
            class="flex h-16 w-16 items-center justify-center rounded-2xl"
            style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);color:var(--gold)"
          >
            <Icon name="lock" size={32} />
          </div>
          <div class="mt-5 text-[26px] font-semibold tracking-tight">AES-256-GCM</div>
          <div class="mt-1.5 text-sm font-medium" style="color:rgba(255,255,255,0.62)">
            {t.security.points[1].d}
          </div>
          <div
            class="mono mt-6 border-t pt-4.5 text-xs break-all"
            style="color:rgba(255,255,255,0.4);line-height:1.8;border-color:rgba(255,255,255,0.1)"
          >
            9f2a7b3c1e88d04a6b5f0c2e7a91d3f4c8b6e2a0d7c5f1b9e3a8d6c4f2b0e7a9
          </div>
        </div>
      </div>
    </div>

    <div class="reveal" data-reveal-delay={120}>
      <Kicker>{t.security.kicker}</Kicker>
      <h2
        class="mt-4 font-semibold tracking-tight"
        style="font-size:clamp(30px,4vw,44px);line-height:1.1"
      >
        {t.security.title}
      </h2>
      <p class="text-muted-foreground mt-3.5 text-[17px] leading-relaxed font-medium">
        {t.security.sub}
      </p>
      <div class="mt-7 grid gap-4.5 sm:grid-cols-2">
        {
          t.security.points.map((p) => (
            <div class="flex items-start gap-3">
              <IconBadge name={p.icon} tint="var(--green)" size={42} radius={12} />
              <div>
                <div class="text-[15px] font-bold tracking-tight">{p.t}</div>
                <div class="text-muted-foreground mt-0.5 text-[13px] leading-snug font-medium">
                  {p.d}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Section>
