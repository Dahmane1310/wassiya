---
import {
  Card,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@workspace/ui/components/card"

const features = [
  {
    title: "Convex backend",
    description:
      "Reactive database and serverless functions in TypeScript, shared by every app in the monorepo.",
  },
  {
    title: "WorkOS AuthKit",
    description:
      "Authentication wired end-to-end — hosted flow on web, PKCE on mobile — validated by the same backend.",
  },
  {
    title: "Web + mobile",
    description:
      "A Next.js app and an Expo app share UI and types, so you build features once and ship everywhere.",
  },
]
---

<section class="mx-auto max-w-5xl px-6 py-16">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((feature) => (
        <Card>
          <CardHeader>
            <CardTitle>{feature.title}</CardTitle>
            <CardDescription>{feature.description}</CardDescription>
          </CardHeader>
        </Card>
      ))
    }
  </div>
</section>
