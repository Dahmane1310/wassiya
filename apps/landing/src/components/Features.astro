---
import IconBadge from "./IconBadge.astro"
import Kicker from "./Kicker.astro"
import Section from "./Section.astro"
import { Card } from "@workspace/ui/components/card"
import type { Dict } from "../i18n/types"

interface Props {
  t: Dict
}
const { t } = Astro.props
---

<Section>
  <div class="reveal mx-auto max-w-[600px] text-center">
    <Kicker center>{t.features.kicker}</Kicker>
    <h2
      class="mt-4 font-semibold tracking-tight"
      style="font-size:clamp(30px,4vw,44px);line-height:1.1"
    >
      {t.features.title}
    </h2>
  </div>

  <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      t.features.items.map((f, i) => (
        <div class="reveal" data-reveal-delay={(i % 3) * 100}>
          <Card className="h-full rounded-[var(--radius)] p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <IconBadge name={f.icon} tint="var(--gold-deep)" size={50} />
            <h3 class="mt-4.5 text-[17.5px] font-bold tracking-tight">{f.t}</h3>
            <p class="text-muted-foreground mt-2 text-sm leading-relaxed font-medium">{f.d}</p>
          </Card>
        </div>
      ))
    }
  </div>
</Section>
