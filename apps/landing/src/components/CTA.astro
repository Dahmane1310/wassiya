---
import { buttonVariants } from "@workspace/ui/components/button"
---

<section class="mx-auto max-w-5xl px-6 py-16">
  <div
    class="bg-card flex flex-col items-center gap-4 rounded-xl border p-10 text-center"
  >
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      Start building today
    </h2>
    <p class="text-muted-foreground max-w-xl text-pretty">
      Clone the template, run one command, and you have a typed full-stack app
      running locally.
    </p>
    <a class={buttonVariants({ size: "lg" })} href="https://docs.convex.dev">
      Read the docs
    </a>
  </div>
</section>
