---
import IconBadge from "./IconBadge.astro"
import Kicker from "./Kicker.astro"
import Section from "./Section.astro"
import type { Dict } from "../i18n/types"

interface Props {
  t: Dict
}
const { t } = Astro.props
const tints = ["var(--primary)", "var(--gold-deep)", "var(--green)"]
---

<Section id="sharia" muted>
  <div class="grid items-center gap-10 md:grid-cols-[0.9fr_1.1fr] md:gap-16">
    <div class="reveal">
      <Kicker>{t.sharia.kicker}</Kicker>
      <h2
        class="mt-4 font-semibold tracking-tight"
        style="font-size:clamp(30px,4vw,44px);line-height:1.1"
      >
        {t.sharia.title}
      </h2>
      <p class="text-muted-foreground mt-3.5 text-[17px] leading-relaxed font-medium">
        {t.sharia.sub}
      </p>
      <div
        class="bg-card border-border mt-7 rounded-[var(--radius)] border p-6 shadow-sm"
        style="border-inline-start:3px solid var(--gold-deep)"
      >
        <div class="text-[21px] font-medium tracking-tight italic" style="line-height:1.4">
          {t.sharia.note}
        </div>
        <div class="text-ink-3 mt-2.5 text-[13px] font-semibold">{t.sharia.notesub}</div>
      </div>
    </div>

    <div class="reveal flex flex-col gap-3.5" data-reveal-delay={140}>
      {
        t.sharia.steps.map((s, i) => (
          <div class="flex items-center gap-4.5">
            <div class="flex shrink-0 flex-col items-center">
              <div class="bg-card border-border text-gold-deep flex h-[46px] w-[46px] items-center justify-center rounded-full border text-[18px] font-bold shadow-sm">
                {i + 1}
              </div>
              {i < t.sharia.steps.length - 1 && <div class="bg-border h-[30px] w-0.5" />}
            </div>
            <div class="bg-card border-border flex flex-1 items-center gap-4 rounded-[var(--radius)] border p-4 shadow-sm">
              <IconBadge name={s.icon} tint={tints[i]} size={44} radius={12} />
              <div class="flex-1">
                <div class="text-base font-bold tracking-tight">{s.t}</div>
                <div class="text-muted-foreground mt-0.5 text-[13.5px] leading-snug font-medium">
                  {s.d}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
