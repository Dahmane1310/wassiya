---
// Maps the design's icon names onto lucide-react (the project's icon library).
// Rendered statically by Astro — no client JS. `color` inherits via currentColor.
import {
  ActivityIcon,
  AppleIcon,
  ArrowRightIcon,
  CheckIcon,
  ChevronDownIcon,
  FileTextIcon,
  FingerprintIcon,
  GiftIcon,
  GlobeIcon,
  HeartIcon,
  HomeIcon,
  KeyRoundIcon,
  LayersIcon,
  LockIcon,
  MenuIcon,
  MoonIcon,
  PlayIcon,
  QuoteIcon,
  ScaleIcon,
  ScrollTextIcon,
  ShieldCheckIcon,
  ShieldIcon,
  StarIcon,
  SunIcon,
  UsersIcon,
  XIcon,
} from "lucide-react"

const MAP = {
  pulse: ActivityIcon,
  apple: AppleIcon,
  arrowR: ArrowRightIcon,
  check: CheckIcon,
  chevD: ChevronDownIcon,
  doc: FileTextIcon,
  fingerprint: FingerprintIcon,
  gift: GiftIcon,
  globe: GlobeIcon,
  heart: HeartIcon,
  home: HomeIcon,
  key: KeyRoundIcon,
  layers: LayersIcon,
  lock: LockIcon,
  menu: MenuIcon,
  moon: MoonIcon,
  play: PlayIcon,
  quote: QuoteIcon,
  scales: ScaleIcon,
  scroll: ScrollTextIcon,
  shield: ShieldIcon,
  shieldCheck: ShieldCheckIcon,
  star: StarIcon,
  sun: SunIcon,
  users: UsersIcon,
  x: XIcon,
} as const

interface Props {
  name: string
  size?: number
  strokeWidth?: number
  class?: string
  fill?: string
}
const { name, size = 22, strokeWidth = 1.7, class: cls, fill } = Astro.props
const Cmp = MAP[name as keyof typeof MAP]
---

{Cmp && <Cmp size={size} strokeWidth={strokeWidth} className={cls} fill={fill ?? "none"} />}
