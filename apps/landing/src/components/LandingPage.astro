---
import FAQ from "./FAQ.astro"
import Features from "./Features.astro"
import FinalCTA from "./FinalCTA.astro"
import Footer from "./Footer.astro"
import Hero from "./Hero.astro"
import HowItWorks from "./HowItWorks.astro"
import Nav from "./Nav.astro"
import Pricing from "./Pricing.astro"
import Security from "./Security.astro"
import Sharia from "./Sharia.astro"
import Stats from "./Stats.astro"
import Switch from "./Switch.astro"
import Testimonials from "./Testimonials.astro"
import Layout from "../layouts/Layout.astro"
import type { Dict, Lang } from "../i18n/types"

interface Props {
  t: Dict
  lang: Lang
}
const { t, lang } = Astro.props
---

<Layout lang={lang} dir={t.dir}>
  <Nav t={t} lang={lang} />
  <main>
    <Hero t={t} />
    <Stats t={t} />
    <HowItWorks t={t} />
    <Sharia t={t} />
    <Security t={t} />
    <Switch t={t} />
    <Features t={t} />
    <Pricing t={t} />
    <Testimonials t={t} />
    <FAQ t={t} />
    <FinalCTA t={t} />
  </main>
  <Footer t={t} lang={lang} />
</Layout>
