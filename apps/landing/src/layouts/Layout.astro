---
import "../styles/global.css"
import type { Lang } from "../i18n/types"

interface Props {
  lang?: Lang
  dir?: "ltr" | "rtl"
  title?: string
  description?: string
  /** Admin-managed og:image (published); falls back to the checked-in PNG. */
  ogImage?: string
}

const {
  lang = "en",
  dir = "ltr",
  ogImage = "/wassiya-pearl-512.png",
  title = lang === "ar" ? "وصية — إرثك، محفوظ بأمان" : "Wassiya — Your legacy, kept safe",
  description =
    lang === "ar"
      ? "خزنة مُشفّرة بمعرفة صفرية لتركتك بالكامل، تُسلَّم لأحبّائك وفق أحكام الشريعة في الوقت المناسب."
      : "A zero-knowledge encrypted vault for your entire estate, released to your loved ones by Islamic law exactly when the time comes.",
} = Astro.props
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- TODO: regenerate the PNGs below as W-mark assets (still the old pearl). -->
    <link rel="apple-touch-icon" href="/wassiya-pearl-180.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Tajawal:wght@400;500;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- No-flash theme boot. Shares localStorage["wl_theme"] with the web
         portal (next-themes storageKey) — same-origin only; "system" or no
         value falls back to the OS preference, matching next-themes. -->
    <script is:inline>
      try {
        var t = localStorage.getItem("wl_theme")
        if (
          t === "dark" ||
          ((!t || t === "system") && matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark")
        }
      } catch (e) {}
    </script>
  </head>
  <body class="font-sans bg-background text-foreground min-h-svh antialiased overflow-x-hidden">
    <slot />
    <script>
      import "../scripts/landing.ts"
    </script>
  </body>
</html>
