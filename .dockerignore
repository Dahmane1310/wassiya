# Dependencies — reinstalled inside the image from the lockfile.
**/node_modules

# Build outputs — regenerated by `turbo build` in the image.
**/.next
**/dist
**/.turbo
**/.expo

# Secrets — never copy local env into the build context.
# (Real values are injected as Docker build args / runtime env.)
**/.env
**/.env.*
!**/.env.example

# VCS / tooling / OS noise.
.git
.gitignore
**/.DS_Store
**/*.log
.vscode
.idea

# This file and Docker artifacts.
Dockerfile
**/Dockerfile
.dockerignore

# Plans / docs not needed for the build.
**/*.md

# NOTE: apps/mobile is intentionally NOT excluded — `turbo prune` reads every
# workspace package.json against the lockfile, and dropping one risks a
# workspace/lockfile mismatch. Its node_modules is already excluded above.
